{
  "name": "embedded-exam-coach",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply embedded-exam-coach --local",
    "db:migrate:remote": "wrangler d1 migrations apply embedded-exam-coach --remote",
    "db:seed:local": "wrangler d1 execute embedded-exam-coach --local --file=migrations/0002_seed.sql",
    "db:seed:remote": "wrangler d1 execute embedded-exam-coach --remote --file=migrations/0002_seed.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251001.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.95.0"
  }
}
